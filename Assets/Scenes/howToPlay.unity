    m_LineSpacing: 1
  m_Text: "H\u1EAFc Ma kh\xF4ng ph\u1EA3i l\xE0 m\u1ED9t th\u1EF1c th\u1EC3 t\u1EF1
    nhi\xEAn... m\xE0 l\xE0 s\u1EF1 h\u1ED9i t\u1EE5 kinh t\u1EE7ng c\u1EE7a nhi\u1EC1u
    H\u1EAFc Linh - nh\u1EEFng k\xFD \u1EE9c o\xE1n h\u1EADn b\u1ECB l\xE3ng qu\xEAn,
    ch\u1ED1i b\u1ECF. Khi ch\xFAng h\u1EE3p l\u1EA1i, n\u1ED7i \u0111au ngh\xECn
    n\u0103m nh\u01B0 m\u1ED9t c\u01A1n b\xE3o \u0111en t\u1ED1i, mu\u1ED1n nghi\u1EC1n
    n\xE1t \xE1nh s\xE1ng c\u1EE7a Tr\u1ED1ng \u0110\u1ED3ng."
